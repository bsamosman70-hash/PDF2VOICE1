# Copy this file to .env and fill in the values
# cp env.example .env

# App
APP_NAME=PDF2Voice API
DEBUG=false
VERSION=1.0.0
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Database (asyncpg driver required)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/pdf2voice

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# JWT — replace SECRET_KEY with a long random string in production
SECRET_KEY=change-this-to-a-very-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=pdf2voice-files

# TTS Providers (at least one must be configured)
ELEVENLABS_API_KEY=
AZURE_TTS_KEY=
AZURE_TTS_REGION=eastus
OPENAI_API_KEY=

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_SCHOLAR_PRICE_ID=
STRIPE_ULTIMATE_PRICE_ID=

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Plan limits
FRONTEND_URL=http://localhost:3000
MAX_FILE_SIZE_MB=500
FREE_AUDIO_HOURS_PER_MONTH=1
PRO_AUDIO_HOURS_PER_MONTH=20
SCHOLAR_AUDIO_HOURS_PER_MONTH=60
ULTIMATE_AUDIO_HOURS_PER_MONTH=200
